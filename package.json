{
  "name": "lap-code",
  "displayName": "Lap Code",
  "description": "Track your coding practice sessions with a live timer and history.",
  "repository": "https://github.com/NicPy/lap-code",
  "bugs": {
    "url": "https://github.com/NicPy/lap-code/issues"
  },
  "version": "1.0.0",
  "publisher": "NicPy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "leetcode",
    "neetcode",
    "timer",
    "countdown",
    "stopwatch",
    "coding practice",
    "interview prep",
    "algorithms",
    "productivity",
    "pomodoro"
  ],
  "icon": "resources/logo.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lap-code-container",
          "title": "Lap Code",
          "icon": "resources/timer-icon.png"
        }
      ]
    },
    "views": {
      "lap-code-container": [
        {
          "type": "webview",
          "id": "lap-code.timerView",
          "name": "Timer"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch:ext": "tsc -watch -p ./",
    "watch:webview": "vite build --watch",
    "dev:webview": "vite",
    "build": "tsc -p ./ && vite build",
    "dev": "concurrently \"npm run watch:ext\" \"npm run watch:webview\""
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "@preact/signals": "^1.3.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "concurrently": "^9.0.0",
    "preact": "^10.23.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
